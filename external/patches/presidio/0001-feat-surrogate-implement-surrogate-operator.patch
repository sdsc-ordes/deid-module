diff --git a/presidio-anonymizer/presidio_anonymizer/operators/surrogate.py b/presidio-anonymizer/presidio_anonymizer/operators/surrogate.py
new file mode 100644
index 00000000..eec05860
--- /dev/null
+++ b/presidio-anonymizer/presidio_anonymizer/operators/surrogate.py
@@ -0,0 +1,58 @@
+"""Replaces the PII text entity with new string."""
+
+import os
+import requests
+from typing import override
+from uuid import uuid4
+
+from presidio_anonymizer.entities import InvalidParamError
+from presidio_anonymizer.operators import Operator, OperatorType
+from presidio_anonymizer.services.validators import validate_type
+
+def generate() -> str:
+    return uuid4().hex
+
+class Surrogate(Operator):
+    """Replace PII text with a random entity from a dictionary based on entity."""
+
+    ENDPOINT: str = "endpoint"
+
+    @override
+    def operate(self, text: str | None = None, params: dict[str, str] | None = None) -> str:
+        """:return: new_value."""
+        if params is None:
+            params = {'entity_type': 'UNKNOWN'}
+
+        endpoint = params.get(self.ENDPOINT) or os.getenv("SURROGATE_ENDPOINT")
+        if not endpoint:
+            raise InvalidParamError("""
+                Surrogate generation service endpoint is required.
+                Provide via 'endpoint' parameter 
+                or set SURROGATE_ENDPOINT environment variable.
+            """)
+
+        pii = {
+            'pii': text,
+            'entity_type': params["entity_type"],
+        }
+        resp = requests.post(endpoint, pii)
+        resp.raise_for_status()
+        surrogate = resp.json()['surrogate']
+
+        return surrogate
+
+    @override
+    def validate(self, params: dict[str, str] | None = None) -> None:
+        """Validate the new value is string."""
+        validate_type(params.get(self.ENDPOINT), self.ENDPOINT, str)
+        pass
+
+    @override
+    def operator_name(self) -> str:
+        """Return operator name."""
+        return "surrogate"
+
+    @override
+    def operator_type(self) -> OperatorType:
+        """Return operator type."""
+        return OperatorType.Anonymize

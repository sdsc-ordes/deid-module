From 949fcc566734267ca7fb898f790c976271775c1f Mon Sep 17 00:00:00 2001
From: cmdoret <cyril.mattheydoret@gmail.com>
Date: Tue, 19 May 2026 17:42:57 +0200
Subject: [PATCH] feat(surrogate): register surrogate operator

---
 presidio-anonymizer/presidio_anonymizer/operators/__init__.py  | 2 ++
 .../presidio_anonymizer/operators/operators_factory.py         | 3 ++-
 2 files changed, 4 insertions(+), 1 deletion(-)

diff --git a/presidio-anonymizer/presidio_anonymizer/operators/__init__.py b/presidio-anonymizer/presidio_anonymizer/operators/__init__.py
index 9b2b4da3..727340fd 100644
--- a/presidio-anonymizer/presidio_anonymizer/operators/__init__.py
+++ b/presidio-anonymizer/presidio_anonymizer/operators/__init__.py
@@ -12,6 +12,7 @@ from .keep import Keep
 from .mask import Mask
 from .redact import Redact
 from .replace import Replace
+from .surrogate import Surrogate
 
 try:
     from .ahds_surrogate import AHDSSurrogate
@@ -31,6 +32,7 @@ __all__ = [
     "Keep",
     "DeanonymizeKeep",
     "Replace",
+    "Surrogate",
     "Custom",
     "Encrypt",
     "Decrypt",
diff --git a/presidio-anonymizer/presidio_anonymizer/operators/operators_factory.py b/presidio-anonymizer/presidio_anonymizer/operators/operators_factory.py
index eee2a3b2..f29dd9d0 100644
--- a/presidio-anonymizer/presidio_anonymizer/operators/operators_factory.py
+++ b/presidio-anonymizer/presidio_anonymizer/operators/operators_factory.py
@@ -16,12 +16,13 @@ from presidio_anonymizer.operators import (
     OperatorType,
     Redact,
     Replace,
+    Surrogate,
 )
 
 logger = logging.getLogger("presidio-anonymizer")
 
 # Predefined operators
-ANONYMIZERS = [Custom, Encrypt, Hash, Keep, Mask, Redact, Replace]
+ANONYMIZERS = [Custom, Encrypt, Hash, Keep, Mask, Redact, Replace, Surrogate]
 if AHDS_AVAILABLE and AHDSSurrogate:
     ANONYMIZERS.append(AHDSSurrogate)
 
-- 

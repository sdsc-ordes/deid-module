From 155d8176991e00e3050599a6f75c2db30b939837 Mon Sep 17 00:00:00 2001
From: cmdoret <cyril.mattheydoret@gmail.com>
Date: Fri, 15 May 2026 19:15:39 +0200
Subject: [PATCH] add surrogate operator

---
 presidio-anonymizer/app.py | 30 ++++++++++++++++++++++++++++++
 1 file changed, 30 insertions(+)

diff --git a/presidio-anonymizer/app.py b/presidio-anonymizer/app.py
index 52f75f41..b718e250 100644
--- a/presidio-anonymizer/app.py
+++ b/presidio-anonymizer/app.py
@@ -26,6 +26,35 @@ WELCOME_MESSAGE = r"""
 |/       |/   \__/(_______/\_______)\_______/(______/ \_______/(_______)
 """
 
+from typing import Dict
+from presidio_anonymizer.operators import Operator, OperatorType
+import uuid  # or use Faker for realistic surrogates
+
+
+class SurrogateOperator(Operator):
+    """Replaces each unique PII value with a stable pseudonym."""
+
+    def operate(self, text: str, params: Dict = None) -> str:
+        entity_type = params["entity_type"]
+        surrogate_map: Dict = params["surrogate_map"]
+
+        key = (entity_type, text)
+        if key not in surrogate_map:
+            # Replace this logic with your actual surrogate generation:
+            surrogate_map[key] = f"<{entity_type}_{uuid.uuid4().hex[:6].upper()}>"
+        return surrogate_map[key]
+
+    def validate(self, params: Dict = None) -> None:
+        if "surrogate_map" not in params:
+            raise ValueError("`surrogate_map` dict is required.")
+        if "entity_type" not in params:
+            raise ValueError("`entity_type` param is required.")
+
+    def operator_name(self) -> str:
+        return "surrogate"
+
+    def operator_type(self) -> OperatorType:
+        return OperatorType.Anonymize
 
 class Server:
     """Flask server for anonymizer."""
@@ -37,6 +66,7 @@ class Server:
         self.app = Flask(__name__)
         self.logger.info("Starting anonymizer engine")
         self.anonymizer = AnonymizerEngine()
+        self.anonymizer.add_anonymizer(SurrogateOperator)
         self.deanonymize = DeanonymizeEngine()
         self.logger.info(WELCOME_MESSAGE)
 

#!/usr/bin/env bash
#
# POST a JSONL file directly to a surrogate service endpoint to import an existing map.
#
# Usage: import-surrogate-map <endpoint_url> <jsonl_path>

set -euo pipefail

usage() {
    echo "Usage: $(basename "$0") <endpoint_url> <jsonl_path>" >&2
    exit 1
}

[[ $# -eq 2 ]] || usage

readonly url="$1"
readonly jsonl_path="$2"

if [[ ! -f "$jsonl_path" ]]; then
    echo "Error: file not found: $jsonl_path" >&2
    exit 1
fi

curl --fail-with-body \
    --show-error \
    -vH 'Content-Type: application/jsonl' \
    -X POST \
    --data-binary "@${jsonl_path}" \
    "$url"
